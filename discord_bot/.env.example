# ===================================
# Discord Bot - Environment Configuration
# ===================================
# This bot is part of the api_substrate monorepo.
# It communicates with the substrate backend at localhost:8284.
# The substrate handles all AI reasoning, memory, and tool execution.

# ===== Substrate Connection =====
# Only change these if the substrate is running on a different host/port
GROK_BASE_URL=http://localhost:8284
GROK_SESSION_ID=discord-bot
# GROK_MODEL=                    # Leave unset to use the substrate's configured model/provider
                                  # Set only if you want the Discord bot to use a different model
GROK_MAX_TOKENS=8192
GROK_API_TIMEOUT_MS=300000

# ===== REQUIRED: Discord =====
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_main_channel_id

# ===== REQUIRED: Bot Behavior =====
USE_SENDER_PREFIX=true
SURFACE_ERRORS=true
RESPOND_TO_DMS=true
RESPOND_TO_MENTIONS=true
RESPOND_TO_BOTS=false
RESPOND_TO_GENERIC=false
TIMEZONE=America/New_York
LOCALE=en-US

# ===== OPTIONAL: Autonomous Mode =====
ENABLE_AUTONOMOUS=false
ENABLE_TIMER=false

# ===== OPTIONAL: Admin Commands =====
ADMIN_USER_ID=your_discord_user_id_here

# ===== OPTIONAL: DM Restriction =====
ALLOWED_DM_USER_ID=

# ===== OPTIONAL: Additional Channels =====
HEARTBEAT_LOG_CHANNEL_ID=
TASKS_CHANNEL_ID=
MIDJOURNEY_CHANNEL_ID=

# ===== OPTIONAL: Spotify Integration =====
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ===== OPTIONAL: Weather Integration =====
OPENWEATHER_API_KEY=
WEATHER_CITY=Munich
WEATHER_COUNTRY_CODE=de
WEATHER_LANGUAGE=de
WEATHER_CITY_DISPLAY=München

# ===== OPTIONAL: GIF Integration =====
TENOR_API_KEY=

# ===== OPTIONAL: Bot Language =====
BOT_LANGUAGE=en

# ===== OPTIONAL: Voice Features =====
# ElevenLabs - Text-to-Speech (outgoing voice messages)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_v3

# OpenAI Whisper - Voice Note Transcription (incoming voice messages)
OPENAI_API_KEY=

# ===== OPTIONAL: Voice Channel Support =====
# Real-time voice conversations in Discord voice channels
# Requires the substrate to be running with /stt and /tts endpoints
VOICE_ENABLED=false
SUBSTRATE_API_URL=http://localhost:8284
SILENCE_THRESHOLD_MS=800

# ===== OPTIONAL: Server Configuration =====
PORT=3001

# ===== OPTIONAL: Stats Script =====
STATS_SCRIPT_PATH=
