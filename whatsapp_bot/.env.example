# WhatsApp Bot Configuration
# ===========================

# Substrate API URL (where Assistant's consciousness runs)
# For local development: http://localhost:8284 (substrate's default port)
# For production: https://relay.aicara.ai
SUBSTRATE_API_URL=http://localhost:8284

# Authentication directory (stores WhatsApp session data)
# This folder will be created automatically on first run
AUTH_DIR=./auth_info_baileys

# User mapping file (for cross-platform sessions)
# This enables unified conversations across Discord, WhatsApp, Telegram, etc.
USER_MAPPING_FILE=./user_mapping.json

# Default session ID (used if no user mapping is configured)
# Platform-specific sessions: whatsapp_<phone_number>
# Unified sessions: set via user_mapping.json
DEFAULT_SESSION_ID=Assistant_whatsapp

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Voice message settings
# Enable voice responses (send TTS audio back to user)
VOICE_RESPONSES_ENABLED=false

# Always respond with voice when user sends voice message
VOICE_REPLIES_TO_VOICE=false
