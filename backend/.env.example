# ============================================
# Substrate AI Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================
# REQUIRED: OpenRouter API Key
# ============================================
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model to use (required)
DEFAULT_LLM_MODEL=openrouter/auto

# xAI Grok Configuration (Primary API)
# Get your API key at: https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here
GROK_API_URL=https://api.x.ai/v1/chat/completions
MODEL_NAME=grok-4-1-fast-reasoning

# ============================================
# OPTIONAL: Mistral AI (Direct API Access)
# ============================================
# Mistral AI offers direct API access to latest models like Magistral Medium
# which has native reasoning and multimodal capabilities
# Get your API key at: https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=your_mistral_api_key_here
# MISTRAL_API_URL=https://api.mistral.ai/v1
# MISTRAL_MODEL=magistral-medium-2509

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8284
HOST=0.0.0.0

# ============================================
# OPTIONAL: Local Embeddings (Ollama)
# ============================================
# If you have Ollama installed locally:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================
# OPTIONAL: PostgreSQL (Advanced Persistence)
# ============================================
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=substrate_ai
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_postgres_password_here

# ============================================
# OPTIONAL: Neo4j (Graph RAG)
# ============================================
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password_here

# ============================================
# OPTIONAL: Discord Integration
# ============================================
# DISCORD_BOT_TOKEN=your_discord_bot_token_here
# TASKS_CHANNEL_ID=your_tasks_channel_id_here
# DEFAULT_USER_ID=your_default_user_id_here
# DISCORD_BOT_URL=http://localhost:3001  # Discord bot API for task scheduling

# ============================================
# LOCALE / TIMEZONE
# ============================================
# Used by Discord tool for task scheduling and time filtering
# Must match the bot-side TIMEZONE / LOCALE_TIMEZONE setting
# LOCALE_TIMEZONE=America/New_York

# ============================================
# OPTIONAL: Telegram Integration
# ============================================
# Get bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_SESSION_ID=telegram_session
# SUBSTRATE_API_URL=http://localhost:8284

# ============================================
# OPTIONAL: Spotify Integration
# ============================================
# SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# ============================================
# OPTIONAL: SOMA Physiological Simulation
# ============================================
# SOMA service URL (defaults to localhost:3002)
# SOMA_URL=http://localhost:3002

# ============================================
# OPTIONAL: Lovense Hardware Integration
# ============================================
# Connect Lovense toys via Game Mode API
# 1. Open Lovense Remote app on your phone
# 2. Go to Settings > Game Mode
# 3. Enable Game Mode and note the IP/Port shown
# 4. Configure values below
# LOVENSE_GAME_IP=192.168.1.100
# LOVENSE_GAME_PORT=30010

# ============================================
# OPTIONAL: Voice Provider Configuration
# ============================================
# Voice provider selection: auto, elevenlabs, hume, polly, pockettts
# 'auto' tries ElevenLabs → Hume → Polly → Pocket TTS based on available keys
VOICE_PROVIDER=elevenlabs

# ElevenLabs TTS (Turbo v2.5 - low latency conversational)
# Reserved for voice messages; phone calls use Hume instead
# Get your API key at: https://elevenlabs.io
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ELEVENLABS_VOICE_ID=your_custom_voice_id_here
# Model options: eleven_turbo_v2_5 (fast), eleven_multilingual_v2, eleven_monolingual_v1
# ELEVENLABS_MODEL=eleven_turbo_v2_5

# Hume Octave TTS (emotionally intelligent speech, custom voices)
# Used for phone calls with Agent's custom voice
# Get your API key at: https://platform.hume.ai
# HUME_API_KEY=your_hume_api_key_here
# HUME_VOICE_ID=your_custom_voice_id_here  # Get from Hume Platform → Voice Library
# HUME_VOICE_NAME=Agent                     # Alternative to ID (less reliable)
# HUME_TTS_VERSION=                        # Omit to auto-route, '1' or '2' to pin
# HUME_ACTING_INSTRUCTIONS=               # e.g. 'warm, conversational, relaxed'

# Hume EVI (Empathic Voice Interface) — integrated STT + LLM + TTS for phone calls
# Replaces the Whisper STT → Consciousness Loop → Hume TTS pipeline with
# Hume's speech-to-speech model for dramatically lower latency on voice calls.
# Reuses HUME_API_KEY, HUME_VOICE_ID, and HUME_VOICE_NAME from above.
# Docs: https://dev.hume.ai/docs/speech-to-speech-evi/overview
HUME_EVI_ENABLED=false                                # Set to 'true' to route phone calls through EVI
# HUME_EVI_VERSION=3                                  # EVI version: '3' or '4-mini' (multilingual)
# HUME_EVI_CONFIG_ID=                                 # Pre-created config ID (auto-created at startup if empty)
# HUME_EVI_LLM_PROVIDER=OPEN_AI                       # Supplemental LLM provider: OPEN_AI, ANTHROPIC, GOOGLE
# HUME_EVI_LLM_MODEL=gpt-4.1                          # Supplemental LLM for reasoning + tool use (non-reasoning = faster)
# HUME_EVI_LLM_API_KEY=                               # API key for supplemental LLM (e.g. your OpenAI key)

# Cartesia Sonic TTS — Low-latency streaming TTS for mobile voice mode
# ~100-200ms time-to-first-byte. Used by the /mobile/voice-stream WebSocket.
# Get your API key at: https://play.cartesia.ai
# CARTESIA_API_KEY=your_cartesia_api_key_here
# CARTESIA_VOICE_ID=                         # Optional, defaults to Barbershop Man
# CARTESIA_MODEL=sonic-2                     # sonic-2 is the latest

# Deepgram — Streaming STT for mobile voice mode
# Real-time transcription via WebSocket with ~500ms utterance endpointing.
# Used by the /mobile/voice-stream WebSocket. Also used as STT fallback.
# Get your API key at: https://console.deepgram.com
# DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Pocket TTS Local TTS (fallback provider)
# Install: pip install pocket-tts
POCKETTTS_URL=http://localhost:8001
POCKETTTS_TIMEOUT=30

# ============================================
# OPTIONAL: Together.ai Image Generation
# ============================================
# Generate character-consistent images via FLUX models
# Get your API key at: https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=your_together_api_key_here
# TOGETHER_IMAGE_ENABLED=true

# Reference images (must be publicly accessible URLs)
# NATE_AVATAR_URL=https://your-domain.com/static/references/agent_avatar.png
# ANGELA_PHOTO_URL=https://your-domain.com/static/references/user_ref.png

# Image generation defaults
# IMAGE_DEFAULT_STEPS=28
# IMAGE_DEFAULT_ASPECT=9:16
