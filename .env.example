# xAI Grok API Configuration
GROK_API_KEY=your-xai-api-key-here
GROK_API_URL=https://api.x.ai/v1/chat/completions
MODEL_NAME=grok-4-1-fast-reasoning

# Database Paths (for backend server)
SQLITE_DB_PATH=./backend/data/db/substrate_state.db
VERSION_DB_PATH=./backend/data/db/versions.db
COST_DB_PATH=./backend/data/costs.db

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=8284

# Model Parameters
N_CTX=131072                  # Context window override (takes priority over per-model defaults)
DEFAULT_MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.7
NATIVE_REASONING=true         # Enable/disable native reasoning for supported models (true/false)

# Voice Provider Configuration
# Options: auto, elevenlabs, pockettts
# 'auto' will use ElevenLabs if API key exists, otherwise Pocket TTS
VOICE_PROVIDER=elevenlabs

# ElevenLabs TTS (Turbo v2.5 - low latency conversational)
# Get your API key at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_agent_voice_id_here
# Model options: eleven_turbo_v2_5 (fast), eleven_multilingual_v2, eleven_monolingual_v1
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Pocket TTS Local TTS (fallback)
# Install: pip install pocket-tts
POCKETTTS_URL=http://localhost:8001

# Together.ai Image Generation (FLUX models)
# TOGETHER_API_KEY=your_together_api_key_here
# NATE_AVATAR_URL=https://your-domain.com/static/references/agent_avatar.png
# ANGELA_PHOTO_URL=https://your-domain.com/static/references/user_ref.png

# ============================================
# POLYMARKET WEATHER TRADING
# ============================================

# CLOB API Credentials (live trading only)
# Get these from: https://docs.polymarket.com/#authentication
# POLYMARKET_PRIVATE_KEY=         # EVM wallet private key for CLOB API
# POLYMARKET_API_KEY=             # From Polymarket CLOB API dashboard
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# Position Tracker Database
POLYMARKET_DB_PATH=./backend/data/db/polymarket_positions.db

# Risk Controls (safe defaults — do not change without understanding Kelly criterion)
POLYMARKET_ENABLED=false
POLYMARKET_PAPER_MODE=true
POLYMARKET_LIVE_MAX_USDC=25               # Hard cap per live trade in USDC (safety limit)
POLYMARKET_MAX_BANKROLL_PCT=2
POLYMARKET_MIN_EDGE=0.06
POLYMARKET_MIN_CONSENSUS=0.65
POLYMARKET_MAX_PER_METRO=1
POLYMARKET_MIN_PRICE=0.10
POLYMARKET_MAX_PRICE=0.90
POLYMARKET_HEARTBEAT_SCAN=false

# Trading Session — isolated context, separate model, Discord journal
POLYMARKET_TRADING_MODEL=              # Model for trading session (empty = use default)
POLYMARKET_DISCORD_CHANNEL=            # Discord channel ID for trading journal posts

# Weather Data — NOAA requires User-Agent header (no API key needed)
NOAA_USER_AGENT=agent-substrate, contact@example.com
